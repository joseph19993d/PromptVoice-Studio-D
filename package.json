{
  "name": "promptvoice-studio",
  "version": "1.0.0",
  "description": "AI-powered desktop app for text generation and voice synthesis. Speak or type prompts, generate AI content, and hear results via TTS.",
  "main": "./out/main/index.js",
  "author": "Joseph Rodelo S",
  "license": "MIT",
  "homepage": "https://github.com/joseph19993d/PromptVoice-Studio-D",
  "scripts": {
    "predev": "node scripts/setup-piper.js",
    "dev": "electron-vite dev",
    "prebuild": "node scripts/setup-piper.js",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.promptvoice.studio",
    "productName": "PromptVoice Studio",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/piper",
        "to": "piper",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
